{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "node",
    "rootDir": "src",
    "baseUrl": "src",
    "outDir": "build",
    "resolveJsonModule": true,
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "types": ["node", "lodash-es"],
    "paths": {
      "@egose/keycloak-fluent": ["./src/index"],
      "@egose/keycloak-fluent/*": ["./src/*"]
    }
  },
  "include": ["./src"]
}
