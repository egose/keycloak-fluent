{
  "name": "@egose/keycloak-fluent",
  "version": "0.6.1",
  "description": "Fluent TypeScript wrapper for the Keycloak Admin API with idempotent provisioning for realms, users, clients, flows, organizations, and admin operations.",
  "keywords": [
    "keycloak",
    "keycloak-admin",
    "keycloak-admin-client",
    "iam",
    "identity-management",
    "provisioning",
    "automation",
    "typescript",
    "declarative",
    "fluent",
    "dsl"
  ],
  "scripts": {
    "dev": "tsc -w",
    "build": "rimraf ./build && tsc",
    "bundle": "tsup",
    "lint-fix": "eslint --fix .",
    "test": "vitest run --no-cache",
    "release": "release-it",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -n .conventional-changelog.mjs -s -r 0 --skip-unstable"
  },
  "type": "module",
  "author": "J.Dev",
  "license": "Apache-2.0",
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/egose/keycloak-fluent"
  },
  "bugs": {
    "url": "https://github.com/egose/keycloak-fluent/issues"
  },
  "homepage": "https://keycloak-fluent.pages.dev/",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/format": "^20.0.0",
    "@eslint/js": "^10.0.0",
    "@release-it/bumper": "^7.0.5",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint__js": "^9.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.8.1",
    "conventional-changelog-cli": "^5.0.0",
    "dotenv": "^17.2.3",
    "eslint": "10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.4",
    "prettier": "4.0.0-alpha.13",
    "release-it": "^19.0.6",
    "rimraf": "^6.1.3",
    "semver": "^7.7.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.4",
    "yargs": "^18.0.0"
  },
  "dependencies": {
    "@keycloak/keycloak-admin-client": "^26.4.7",
    "lodash-es": "^4.17.21"
  },
  "pnpm": {
    "overrides": {
      "conventional-changelog-conventionalcommits": "^9.0.0"
    }
  }
}
